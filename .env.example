# Publiek contactformulier via EmailJS
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id_here
NEXT_PUBLIC_EMAILJS_USER_ID=your_user_id_here

# Admin Dashboard Authentication
ADMIN_PASSWORD=changeme123

# Beveiligd factuur- en glasbewassingssysteem
DATABASE_URL=your_neon_postgres_connection_string
FACTUUR_SESSIE_TOKEN=replace_with_a_long_random_session_token

# Optioneel: facturen automatisch verzenden via iCloud Mail SMTP.
# Gebruik hier uitsluitend een app-specifiek Apple-wachtwoord, nooit je gewone Apple-wachtwoord.
FACTUUR_SMTP_HOST=smtp.mail.me.com
FACTUUR_SMTP_PORT=587
FACTUUR_SMTP_USER=your_icloud_login@icloud.com
FACTUUR_SMTP_APP_PASSWORD=your_apple_app_specific_password
FACTUUR_FROM_EMAIL=info@frisspits.nl
FACTUUR_IMAP_HOST=imap.mail.me.com
FACTUUR_IMAP_PORT=993

# Optioneel: lokale map waar PDF's ook naartoe worden gekopieerd.
FACTUUR_ICLOUD_MAP=
